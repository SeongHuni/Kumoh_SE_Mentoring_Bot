# 검증된 기본 sample은 local입니다. openai/auto로 전환하기 전 provider-matched index/evaluation과
# provider별 threshold 설정·검증을 완료하세요. auto는 key가 있으면 OpenAI로 전환합니다.
AI_PROVIDER=local

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
# 임베딩·청킹 설정을 바꾸면 반드시 전체 인덱스를 다시 만드세요.
EMBEDDING_DIMENSIONS=1536
CHUNK_SIZE=900
CHUNK_OVERLAP=150
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=se_mentor_posts
RAW_POSTS_PATH=./data/raw/posts.json
TOPIC_RULES_PATH=./data/topic_rules.json
RAG_TOP_K=5
# 0.10은 local hash/46건 historical tuning에만 근거하며 OpenAI에는 검증되지 않았으므로
# OpenAI provider에서 그대로 신뢰하지 마세요.
# 2026-07-14의 46건 historical tuning snapshot에서 noise max 0.0924(scholarship-apply)와
# true-positive min 0.1161(course-openings-lookup) 사이 0.10을 선택했습니다.
# data/provider 변경 후 현재 31문항 이상에서 positive/negative retrieval score 분포를 다시 측정하고,
# false-positive max와 true-positive min의 margin 근거로 threshold를 결정해
# docs/PROJECT_STATUS.md와 평가 기록에 남기세요.
RAG_MIN_SCORE=0.10

# Crawling
CRAWLER_DELAY_SECONDS=1.0
CRAWLER_TIMEOUT_SECONDS=20.0
SEBOARD_API_URL=
SEBOARD_HEADLESS=true

# API / frontend
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_PORT=8000
FRONTEND_PORT=3000
