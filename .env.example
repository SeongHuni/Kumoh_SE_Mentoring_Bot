# AI provider: auto uses OpenAI when a key exists, otherwise local mode.
AI_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
# 임베딩·청킹 설정을 바꾸면 반드시 전체 인덱스를 다시 만드세요.
EMBEDDING_DIMENSIONS=1536
CHUNK_SIZE=900
CHUNK_OVERLAP=150
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=se_mentor_posts
RAW_POSTS_PATH=./data/raw/posts.json
TOPIC_RULES_PATH=./data/topic_rules.json
RAG_TOP_K=5
# 로컬 해시 임베딩 보정값. OpenAI provider는 0.20부터 재평가하세요.
# 46건 baseline 기준 노이즈 최고점 0.0924(scholarship-apply)와 참양성 최저점
# 0.1161(course-openings-lookup) 사이에서 0.10으로 재조정함(2026-07-14 평가 근거).
RAG_MIN_SCORE=0.10

# Crawling
CRAWLER_DELAY_SECONDS=1.0
CRAWLER_TIMEOUT_SECONDS=20.0
SEBOARD_API_URL=
SEBOARD_HEADLESS=true

# API / frontend
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_PORT=8000
FRONTEND_PORT=3000
