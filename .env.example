# AI provider: auto uses OpenAI when a key exists, otherwise local mode.
AI_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=se_mentor_posts
RAW_POSTS_PATH=./data/raw/posts.json
RAG_TOP_K=5
RAG_MIN_SCORE=0.20

# Crawling
CRAWLER_DELAY_SECONDS=1.0
CRAWLER_TIMEOUT_SECONDS=20.0
SEBOARD_API_URL=
SEBOARD_HEADLESS=true

# API / frontend
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_PORT=8000
FRONTEND_PORT=3000
